<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.hitacal.ui.LoginController"
           stylesheets="@../css/hitacal.css"
           style="-fx-background-color: #F5ECD7;">
    <VBox maxWidth="440" maxHeight="600" spacing="0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(59,31,14,0.3), 24, 0, 0, 6);">

        <!-- Header -->
        <VBox styleClass="header-bar" spacing="4" alignment="CENTER">
            <Label text="🐢  hitacal AI" styleClass="header-title"/>
            <Label text="Your personalized calorie companion" styleClass="header-subtitle"/>
        </VBox>

        <!-- Turtle Canvas -->
        <StackPane style="-fx-background-color: #FDF6EC; -fx-padding: 16 0 0 0;" alignment="CENTER">
            <Canvas fx:id="turtleCanvas" width="140" height="120"/>
        </StackPane>

        <!-- Login Form -->
        <VBox spacing="14" style="-fx-padding: 24 36 30 36;">
            <Label text="Welcome back!" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#3B1F0E;"/>

            <VBox spacing="6">
                <Label text="Username" style="-fx-font-weight:bold; -fx-text-fill:#6B3A2A;"/>
                <TextField fx:id="usernameField" promptText="Enter your username"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" style="-fx-font-weight:bold; -fx-text-fill:#6B3A2A;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"/>
            </VBox>

            <Label fx:id="errorLabel" text="" style="-fx-text-fill:#8B1A1A; -fx-font-size:12px;" wrapText="true"/>

            <Button fx:id="loginBtn" text="Login  🐢" onAction="#onLogin"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Separator/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="New User" onAction="#onNewUser" styleClass="btn-secondary"/>
                <Button text="Admin Login" onAction="#onAdminLogin" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
